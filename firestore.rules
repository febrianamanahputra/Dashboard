rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 AUTH HELPERS
    function isSignedIn() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. VALIDATION BLUEPRINTS (Relaxed for accessibility)
    function isValidLocation(data) {
      return data.name is string && data.name.size() > 0;
    }

    function isValidStock(data) {
      return data.materialName is string && 
             data.quantity is number && 
             data.unit is string;
    }

    function isValidRAPItem(data) {
      return data.materialName is string && 
             data.quantity is number && 
             data.unit is string &&
             data.locationId is string;
    }

    function isValidMaterialRequest(data) {
      return data.materialName is string && 
             data.quantity is number && 
             data.unit is string && 
             data.locationId is string &&
             data.status is string &&
             data.history is list;
    }

    function isValidNotification(data) {
      return data.message is string && 
             data.timestamp is number && 
             data.targetRole is string;
    }

    // 1. MASTER GATE (Relational Sync)
    function parentLocationExists(locationId) {
      return exists(/databases/$(database)/documents/locations/$(locationId));
    }

    // 8. RULES
    match /locations/{locationId} {
      allow read, write: if true;

      match /stock/{stockId} {
        allow read, write: if true;
      }

      match /rapData/{itemId} {
        allow read, write: if true;
      }
    }

    match /{path=**}/rapData/{itemId} {
      allow read: if true;
    }

    match /requests/{requestId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
